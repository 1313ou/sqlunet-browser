<com.google.android.material.search.SearchView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/search_view"
	style="@style/MySearchViewStyle"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:hint="@string/hint_search"
	app:headerLayout="@layout/searchview_header"
	app:layout_anchor="@id/search_bar"
	app:layout_behavior="com.google.android.material.search.SearchView$Behavior">

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/search_view_suggestion_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:theme="@style/MySurfaceOverlay"
		app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</com.google.android.material.search.SearchView>
