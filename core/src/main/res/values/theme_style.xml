<resources>

	<!-- O V E R L A Y S -->

	<!-- Custom surface overlay -->
	<style name="MySurfaceOverlay" parent="ThemeOverlay.Material3">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
	</style>

	<!-- Search view -->
	<style name="MySearchViewOverlay" parent="">
		<item name="colorSurfaceContainerHigh">?attr/colorCustom</item> <!-- full screen -->
		<item name="colorOnSurface">?attr/colorOnCustom</item> <!-- back icon -->
		<item name="colorOnSurfaceVariant">?attr/colorOnCustom</item> <!-- hint text -->
		<item name="materialSearchViewToolbarStyle">@style/MySearchView.Toolbar</item>
	</style>

	<style name="MySearchView.Toolbar" parent="Widget.Material3.SearchView.Toolbar">
		<item name="android:background">?attr/colorCustom</item>
	</style>

	<!-- S T Y L E S -->

	<!-- App bar -->
	<style name="MyAppBarLayout" parent="Widget.Material3.AppBarLayout">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
		<!-- This prevents the AppBarLayout from applying an elevation overlay that would cover the statusBarColor -->
		<item name="liftOnScroll">false</item>
	</style>

	<!-- Dropdown list -->
	<style name="MyDropDownListViewStyle" parent="Widget.AppCompat.ListView.DropDown">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
	</style>

	<!-- Dropdown item -->
	<style name="MyDropDownItemStyle" parent="Widget.AppCompat.DropDownItem.Spinner">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
		<item name="android:textSize">14sp</item>
	</style>

	<!-- Autocomplete -->
	<style name="MyAutoCompleteTextViewStyle" parent="Widget.AppCompat.Light.AutoCompleteTextView">
		<item name="android:popupBackground">?attr/colorCustom</item>
	</style>

</resources>