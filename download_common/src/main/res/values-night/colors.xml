<resources>

	<!-- R A W -->

	<color name="red_color">#EF9A9A</color>
	<color name="green_color">#A5D6A7</color>
	<color name="blue_color">#80CBC4</color>

	<!-- M A I N -->

	<!-- button -->
	<color name="ok_button_color">@color/green_color</color>
	<color name="err_button_color">@color/red_color</color>

	<!-- report -->
	<color name="storageTypeBackColor">#FFFF80</color>
	<color name="storageTypeForeColor">#000000</color>

	<color name="dirTypeBackColor">#800080</color>
	<color name="dirTypeForeColor">#FFFFFF</color>

	<color name="storageValueBackColor">@android:color/transparent</color>
	<color name="storageValueForeColor">#FFFFFF</color>

	<color name="dirValueBackColor">@android:color/transparent</color>
	<color name="dirValueForeColor">@color/blue_color</color>

	<color name="dirOkBackColor">@android:color/transparent</color>
	<color name="dirOkForeColor">@color/green_color</color>

	<color name="dirFailBackColor">@android:color/transparent</color>
	<color name="dirFailForeColor">@color/red_color</color>

	<array name="palette_storage">

		<item>@color/storageTypeBackColor</item>
		<item>@color/storageTypeForeColor</item>

		<item>@color/storageValueBackColor</item>
		<item>@color/storageValueForeColor</item>

		<item>@color/dirTypeBackColor</item>
		<item>@color/dirTypeForeColor</item>

		<item>@color/dirValueBackColor</item>
		<item>@color/dirValueForeColor</item>

		<item>@color/dirOkBackColor</item>
		<item>@color/dirOkForeColor</item>

		<item>@color/dirFailBackColor</item>
		<item>@color/dirFailForeColor</item>

	</array>
</resources>
